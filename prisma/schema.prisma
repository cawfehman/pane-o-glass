// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id         String     @id @default(cuid())
  username   String     @unique
  password   String?
  firstName  String?
  lastName   String?
  role       String     @default("USER")
  isExternal Boolean    @default(false)
  lastLogin  DateTime?
  sessionTimeout Int        @default(10)
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
  auditLogs      AuditLog[]
  firewallQueries FirewallQueryHistory[]
  feedback       Feedback[]
}

model FirewallQueryHistory {
  id        String   @id @default(cuid())
  userId    String?  
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  command   String   // "Check Shun", "Remove Shun"
  targetIp  String
  targetName String? // e.g. "FW01"
  ipAsn      String?
  ipAsName   String?
  ipAsDomain String?
  ipCountry  String?
  ipCountryCode String?
  createdAt DateTime @default(now())
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?  
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  action    String
  details   String
  ipAddress String?
  createdAt DateTime @default(now())
}

model HealthProbe {
  id        String   @id @default(cuid())
  ipAddress String
  userAgent String?
  createdAt DateTime @default(now())
}
model ToolPermission {
  id        String   @id @default(cuid())
  toolId    String   // e.g. "firewall", "ise", "ise-failures", "hibp-account", "hibp-domain"
  role      String   // "ADMIN", "ANALYST", "USER"
  isEnabled Boolean  @default(true)
  updatedAt DateTime @updatedAt

  @@unique([toolId, role])
}

model Feedback {
  id        String   @id @default(cuid())
  userId    String?  
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  tool      String   // URL or Name of the tool
  subject   String
  body      String
  createdAt DateTime @default(now())
}

model BackgroundJob {
  id        String   @id @default(cuid())
  name      String   @unique
  lastRun   DateTime @default(now())
  status    String   // "SUCCESS", "FAILURE"
  message   String?
}
