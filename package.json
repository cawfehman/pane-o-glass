{
  "name": "pane-o-glass",
  "version": "5.14.5",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "npm run build:scripts && next build",
    "build:scripts": "npx esbuild scripts/cron/*.ts scripts/utils/*.ts --outdir=dist-scripts --platform=node --format=cjs",
    "start": "next start",
    "lint": "next lint",
    "deploy": "git push origin main --follow-tags && git push production main --follow-tags",
    "deploy:patch": "npm version patch && npm run deploy",
    "deploy:minor": "npm version minor && npm run deploy",
    "deploy:major": "npm version major && npm run deploy",
    "test": "playwright test",
    "test:ui": "playwright test --ui",
    "test:setup": "ts-node tests/setup/seed-test-users.ts"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "@tailwindcss/postcss": "^4.3.2",
    "@types/bcryptjs": "^2.4.6",
    "axios": "^1.13.6",
    "bcryptjs": "^3.0.3",
    "clsx": "^2.1.1",
    "dotenv": "^17.3.1",
    "ldapts": "^8.1.7",
    "lucide-react": "^0.473.0",
    "next": "16.1.6",
    "next-auth": "^5.0.0-beta.30",
    "node-ssh": "^13.2.1",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "postcss": "^8.5.19",
    "prisma": "^5.22.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "tailwind-merge": "^2.5.2",
    "tailwindcss": "^4.3.2",
    "xml2js": "^0.6.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/node": "^20.19.43",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/xml2js": "^0.4.14",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "ts-node": "^10.9.2",
    "typescript": "^5"
  }
}
